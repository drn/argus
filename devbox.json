{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": [
    "go@1.25",
    "gotestsum@latest"
  ],
  "shell": {
    "init_hook": [],
    "scripts": {
      "build": "go build ./...",
      "test": "go test -race -count=1 ./...",
      "test:watch": "gotestsum --watch ./...",
      "test:cover": "go test -race -count=1 -coverprofile=coverage.out ./... && go tool cover -func=coverage.out | tail -1",
      "vet": "go vet ./..."
    }
  }
}
